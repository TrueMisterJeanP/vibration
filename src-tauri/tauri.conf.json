{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vibration",
  "version": "1.0.0",
  "identifier": "fr.webtchat.desktop",
  "build": {
    "frontendDist": "../web",
    "devUrl": "http://localhost:8080/login.html",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "url": "login.html",
        "title": "Vibration",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
